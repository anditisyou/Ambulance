{
  "name": "emergency-response-system",
  "version": "2.0.0",
  "description": "Production-ready emergency response dispatch system",
  "main": "index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --runInBand --forceExit",
    "test:cov": "jest --coverage --runInBand --forceExit",
    "lint": "eslint . --ext .js",
    "test:load": "node scripts/load-test.js",
    "test:load:quick": "node scripts/load-test.js 60 100",
    "test:load:full": "node scripts/load-test.js 300 1000"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^7.1.0",
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.3",
    "cloudinary": "^2.0.0",
    "connect-mongo": "^5.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.19.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.3",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^5.0.1",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.13.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "form-data": "^4.0.5",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^8.16.1",
    "nodemon": "^3.1.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": [],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "middleware/**/*.js",
      "utils/**/*.js"
    ]
  },
  "directories": {
    "test": "tests"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
